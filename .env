# ============================================
# 明心战略新闻日报 - 环境变量配置
# ============================================

# 服务端口
PORT=3000

# 环境模式 (development/production)
NODE_ENV=development

# ============================================
# Longbridge API 配置
# 如需获取实时股票数据，请配置 Longbridge API
# 文档: https://open.longbridgeapp.com/
# ============================================
LONGBRIDGE_APP_KEY=a4ee5cca06ea39ff2ea48cb12c7d1d43
LONGBRIDGE_APP_SECRET=b03dff25d2ea0fd7bbc2201a820d09a85f546e06a4634043bacd62068d149fb5
# 获取 access_token 方法：
# 1. 运行: python scripts/get_longbridge_token.py
# 2. 在浏览器中授权
# 3. 将获取的 token 填入下方
LONGBRIDGE_ACCESS_TOKEN=


# ============================================
# AI 服务配置 (可选，用于自动生成摘要)
# ============================================
# ANTHROPIC_API_KEY=your_claude_api_key
# OPENAI_API_KEY=your_openai_api_key

# ============================================
# 数据抓取配置
# ============================================
# 抓取超时时间（毫秒）
FETCH_TIMEOUT=30000
# 用户代理
USER_AGENT=Mozilla/5.0 (compatible; MingxinDaily/1.0)

# ============================================
# 定时任务配置
# ============================================
# 日报生成时间（Cron表达式，默认每天08:00）
SCHEDULE_DAILY=0 8 * * *
# 时区
TZ=Asia/Shanghai
